//
//  Purpose: Template for storing API keys and secrets.
//  Instructions:
//  1. Copy this file to Secrets.xcconfig (which is git-ignored)
//  2. Replace YOUR_WHISPER_API_KEY_HERE with your actual API key
//  3. Add Secrets.xcconfig to your Xcode project configuration
//
//  IMPORTANT: Never commit the actual Secrets.xcconfig file to version control!
//

// Whisper API Configuration
WHISPER_API_KEY = YOUR_WHISPER_API_KEY_HERE
WHISPER_API_BASE_URL = https:/$()/api.openai.com/v1

// Environment
ENVIRONMENT = development
